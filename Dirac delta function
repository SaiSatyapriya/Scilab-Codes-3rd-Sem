clc; clf; clear;

a = -3;
b = 3;

x = a:0.001:b;

sigma = 0.001;

function y = f(x)
    y = (x + 3)./(sqrt(2*%pi)*sigma) .* exp(-(x-2).^2./(2*sigma^2));
endfunction

I = intg(a, b, f);

disp("sigma = " + string(sigma) + "   Integral = " + string(I));

plot2d(x, f(x), 2);
xgrid(1,1,3);
xlabel("x");
ylabel("Integrand");
title("Direct Delta Function Approximation");
